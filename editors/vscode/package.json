{
  "name": "sui-move-analyzer",
  "displayName": "Sui Move Analyzer",
  "description": "Language server support for Sui Move smart contract development",
  "version": "0.1.0",
  "publisher": "KlyntLabs",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/KlyntLabs/sui-move-analyzer"
  },
  "bugs": {
    "url": "https://github.com/KlyntLabs/sui-move-analyzer/issues"
  },
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "keywords": [
    "move",
    "sui",
    "blockchain",
    "smart contracts",
    "lsp"
  ],
  "activationEvents": [
    "workspaceContains:Move.toml"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "move",
        "aliases": [
          "Move",
          "move"
        ],
        "extensions": [
          ".move"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "configuration": {
      "title": "Sui Move Analyzer",
      "properties": {
        "suiMoveAnalyzer.server.path": {
          "type": "string",
          "default": "sui-move-analyzer",
          "description": "Path to the sui-move-analyzer binary. Defaults to looking for it on PATH."
        },
        "suiMoveAnalyzer.server.logLevel": {
          "type": "string",
          "default": "info",
          "enum": [
            "error",
            "warn",
            "info",
            "debug",
            "trace"
          ],
          "description": "Log level for the language server."
        },
        "suiMoveAnalyzer.trace.server": {
          "type": "string",
          "default": "off",
          "enum": [
            "off",
            "messages",
            "verbose"
          ],
          "description": "Traces the communication between VS Code and the language server."
        }
      }
    }
  },
  "scripts": {
    "compile": "npm run check-types && npm run bundle",
    "check-types": "tsc --noEmit",
    "bundle": "esbuild src/extension.ts --bundle --outfile=out/extension.js --external:vscode --format=cjs --platform=node --sourcemap",
    "watch": "npm run bundle -- --watch",
    "package": "npm run compile && vsce package",
    "publish": "npm run compile && vsce publish"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.2.3",
    "@types/vscode": "^1.75.0",
    "@vscode/vsce": "^3.0.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.5.0"
  }
}
